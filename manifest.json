{
  "manifest_version": 3,
  "name": "Video Zoomer",
  "version": "1.4",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
    "commands": {
      "zoom-in-shortcut": {
        "suggested_key": {
          "default": "Ctrl+Shift+Z"
        },
        "description": "Zoom into video"
      },
      "zoom-out-shortcut": {
        "suggested_key": {
          "default": "Ctrl+Shift+X"
        },
        "description": "Zoom out of video"
      },
      "zoom-reset-shortcut": {
        "suggested_key": {
          "default": "Ctrl+Shift+R"
        },
        "description": "Reset video zoom"
      }
    },
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Zoomer",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}