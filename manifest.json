{
  "manifest_version": 3,
  "name": "Video Zoomer",
  "version": "1.4",
  "description": "Chrome extension to zoom into any HTML5 video using keyboard shortcuts",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["<all_urls>"],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon.png",
    "48": "icons/icon.png",
    "128": "icons/icon.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Video Zoomer",
    "default_icon": "icons/icon.png"
  },
  "background": {
    "service_worker": "background.js"
  }
}
